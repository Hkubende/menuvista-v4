PORT=8787
NODE_ENV=production

# Comma-separated frontend origins, or * during development
CORS_ORIGIN=*

# sandbox | production
MPESA_ENV=sandbox

# Safaricom Daraja credentials
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# Public URL that Safaricom can call after STK prompt
MPESA_CALLBACK_URL=https://your-backend.example.com/callback

# Usually CustomerPayBillOnline for paybill, or CustomerBuyGoodsOnline for till
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Optional override; defaults to MPESA_SHORTCODE
MPESA_PARTY_B=
